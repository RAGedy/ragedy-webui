# RAGedy Ann — Environment Configuration
# ─────────────────────────────────────────────────
# Quick start:
#   cp .env.example .env
#   docker compose up -d --build
#
# The WebUI will be at http://localhost:3000
# LiteLLM admin UI at http://localhost:4005/ui

# ── WebUI ──────────────────────────────────────────
OPENAI_API_BASE_URL=http://litellm:4000/v1
OPENAI_API_KEY=
OLLAMA_BASE_URL=
WEBUI_NAME=RAGedy Ann
CORS_ALLOW_ORIGIN=*
FORWARDED_ALLOW_IPS=*
SCARF_NO_ANALYTICS=true
DO_NOT_TRACK=true
ANONYMIZED_TELEMETRY=false

# ── LiteLLM ──────────────────────────────────────
LITELLM_MASTER_KEY=
LITELLM_SALT_KEY=
OPENROUTER_API_KEY=

# ── Qdrant (vector DB) ──────────────────────────
QDRANT_URL=
QDRANT_API_KEY=
QDRANT_COLLECTION_NAME=qdrant_collection_diig_rag
QDRANT_VECTOR_SIZE=1536

# ── Cohere (embeddings) ─────────────────────────
COHERE_API_KEY=
COHERE_EMBED_MODEL=embed-v4.0
COHERE_EMBED_BATCH_SIZE=32

# ── RAG tuning (defaults are fine) ───────────────
RAG_AGENT_MODEL_NAME=diig-rag-agent
RAG_GENERATION_MODEL=litellm-or-gpt-4o-mini
RAG_RETRIEVAL_TOP_K=6
RAG_CHUNK_SIZE=1200
RAG_CHUNK_OVERLAP=200
RAG_REQUEST_TIMEOUT_SECONDS=120

# ── OAuth ────────────────────────────────────────
OAUTH_CLIENT_ID=
OAUTH_CLIENT_SECRET=
OPENID_PROVIDER_URL=
OAUTH_PROVIDER_NAME=Descope
OAUTH_SUB_CLAIM=sub
ENABLE_FORWARD_USER_INFO_HEADERS=True
ENABLE_OAUTH_SIGNUP=True
ENABLE_LOGIN_FORM=True
